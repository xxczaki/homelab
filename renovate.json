{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": ["github>xxczaki/renovate-config"],
	"argocd": {
		"fileMatch": ["apps/.+\\.yaml$"]
	},
	"packageRules": [
		{
			"description": "Schedule discord-bot updates between 3 AM and 8 PM",
			"matchPackageNames": ["discord-bot"],
			"schedule": ["* 3-20 * * *"]
		}
	],
	"ignoreTests": true
}
